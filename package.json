{
  "name": "agent-sql",
  "version": "0.4.0",
  "description": "SQL CLI for AI agents",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun build src/index.ts --outdir dist --target=bun --sourcemap",
    "build:release": "sh ./scripts/build-release-assets.sh",
    "dev": "bun run bin/agent-sql.bun.js",
    "prepare": "simple-git-hooks",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:mocked": "bun test test/resolve-mocked.isolated.ts",
    "lint": "oxlint src/ test/",
    "lint:fix": "oxlint --fix src/ test/",
    "format": "oxfmt --write src/ test/",
    "format:check": "oxfmt --check src/ test/",
    "release": "sh ./scripts/release.sh"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "js-yaml": "^4.1.1",
    "libpg-query": "^15.2.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "bun-types": "^1.3.8",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.8.2"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint:fix && bun run format"
  },
  "engines": {
    "node": ">=24"
  }
}
